.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker artifacts
docker-compose.yml
docker-compose.override.yml
Dockerfile
.dockerignore

# Kurigram session file (mounted as a volume instead)
user/session/__pycache__/

# Logs
*.log

# Local DB files
*.db
*.sqlite3

# Data dir is mounted as a volume
data/
