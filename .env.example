# ── Telegram Bot ──
BOT_TOKEN=your_bot_token_here

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cupagent

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Grapes Market (static API key via X-API-Token header) ──
GRAPES_API_TOKEN=

# ── Kurigram user session (for MRKT/Portal initData) ──
# Either run `python scripts/login.py` to create user/session/session.string,
# OR set SESSION_STRING here. API_ID/API_HASH are required either way.
API_ID=0
API_HASH=
SESSION_STRING=
GRAPES_BOT_USERNAME=grapesmarket_bot
MRKT_BOT_USERNAME=mrkt
PORTAL_BOT_USERNAME=portals
# Mini App short_name (the part after ?startapp= in t.me links)
MRKT_APP_SHORT_NAME=app
PORTAL_APP_SHORT_NAME=market

# ── Price update interval (seconds) ──
PRICE_UPDATE_INTERVAL=300

# ── Whitelist (comma-separated Telegram user IDs; empty = open to everyone) ──
WHITELIST=

# ── OpenRouter (LLM) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=1500
# Comma-separated fallback models tried when primary returns 429/5xx.
# Free models (":free") are rate-limited harder, so retries have backoff.
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-v4-flash,google/gemma-4-26b-a4b:free,google/gemma-4-31b:free,tencent/hy3:free,nvidia/nemotron-3-super:free

# ── Anti-spam (obvious flood only) ──
# Blocks a user only after sending the SAME message `threshold` times
# within `window` seconds. Normal conversation is never blocked.
ANTISPAM_DUPLICATE_WINDOW=60
ANTISPAM_DUPLICATE_THRESHOLD=10
ANTISPAM_BLOCK_SECONDS=120

# ── GiftWiki API (https://api.giftwiki.tg/docs, X-API-Key header) ──
GIFTWIKI_TOKEN=

# ── Moomin Market API (https://api.moomin.cfd/market/v1, X-API-Key) ──
# Cross-market gift collection aggregator (snapshot, OHLC candles).
# Optional — if empty, Moomin snapshot/history tools are disabled.
MOOMIN_API_KEY=

# ── GetGems API (https://api.getgems.io/public-api, Bearer token) ──
# Pre-issued GGLLM_... token from TON Proof auth. Optional — if empty,
# GetGems is omitted from price sources.
GETGEMS_API_TOKEN=

# ── Crypto / Fiat APIs (no auth, override only if proxied) ──
# BINANCE_BASE_URL=https://api.binance.com/api/v3
# EXCHANGERATE_BASE_URL=https://open.er-api.com/v6
# CBR_DAILY_URL=https://www.cbr-xml-daily.ru/daily_json.js
